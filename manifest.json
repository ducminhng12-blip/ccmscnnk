{
  "manifest_version": 3,
  "name": "GDT Auto-Fill Pro",
  "version": "3.1",
  "description": "Đăng nhập hàng loạt MST từ Excel với Logo chuyên nghiệp",
  "permissions": ["storage", "webRequest"],
  "host_permissions": [
    "https://hoadondientu.gdt.gov.vn/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Mở bảng điều khiển GDT",
    "default_icon": "logo.png"
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  }
}
